PORT=3000
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=

# 单个公众号 RSS（wechat-download-api / wechatrss SaaS 控制台复制）
# WECHAT_RSS_URL=https://wechatrss.waytomaster.com/api/rss/<fakeid>?token=<JWT>&limit=60

# 多个公众号：运行 npm run wechat:subscribe 后把脚本输出的整行粘贴到这里
# WECHAT_RSS_URLS='["https://wechatrss.waytomaster.com/api/rss/xxx?token=...&limit=60","..."]'

# 每路 RSS 拉取条数上限（服务端会强制改写到 URL 的 limit 参数，默认 60）
# WECHAT_RSS_PER_FEED_LIMIT=60

WECHAT_RSS_POLL=true

# 首次 RSS 同步会清空本地人工状态（候选/复核等）；之后同步会合并保留。
# 需要恢复「始终合并」旧行为时设为 true，或删除 data/rss-sync-state.json 后只首 sync 再清空一次。
# RSS_FORCE_MERGE_MANUAL=false
